# ─────────────────────────────────────────────────────────────────────────────
# Restaurant Reservation Monitor — Configuration
# ─────────────────────────────────────────────────────────────────────────────
# INSTRUCTIONS:
#   1. Copy this file and rename the copy to: config.env
#   2. Fill in each value below (remove the placeholder text)
#   3. Never share config.env — it contains your passwords and API keys
# ─────────────────────────────────────────────────────────────────────────────

# ── Resy account (the email and password you use to log in to resy.com) ──────
RESY_EMAIL=your_resy_email@example.com
RESY_PASSWORD=your_resy_password

# ── OpenTable account (email and password for opentable.com) ─────────────────
# Leave blank if you only use Resy
OPENTABLE_EMAIL=your_opentable_email@example.com
OPENTABLE_PASSWORD=your_opentable_password

# ── Gmail (for email alerts) ──────────────────────────────────────────────────
# Gmail — sender account (must have 2-Step Verification enabled)
GMAIL_ADDRESS=your.gmail@gmail.com

# App Password (not your regular Gmail password)
# Create one at: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# The email address that receives the alerts (can be same as GMAIL_ADDRESS)
ALERT_EMAIL_TO=your.email@example.com
